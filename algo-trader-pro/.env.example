# =============================================================================
# AlgoTrader Pro - Environment Variables Template
# Copy this file to .env and fill in your real values
# NEVER commit .env to version control
# =============================================================================

# =============================================================================
# PHASE 1 - Active now (Paper Trading with CoinGecko + CryptoPanic)
# =============================================================================

# Application
APP_ENV=paper
LOG_LEVEL=INFO

# Data provider: se BYBIT_API_KEY e BYBIT_API_SECRET sono impostati, usa Bybit (WebSocket+REST).
# Altrimenti usa CoinGecko (solo REST polling).
DATA_PROVIDER=coingecko

# CryptoPanic News API
# Get your key at: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=your_key_here
CRYPTOPANIC_BASE_URL=https://cryptopanic.com/api/developer/v2

# CoinGecko (no API key required for free tier)
# For Pro tier: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# Fear & Greed Index (no key required)
# https://alternative.me/crypto/fear-and-greed-index/

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=sqlite:///./database/algotrader.db

# =============================================================================
# PHASE 2 - After Bybit KYC (Uncomment when ready for live trading)
# =============================================================================

# Bybit Exchange API — se impostati, abilita WebSocket + REST (stessa struttura di locale)
# Generate keys at: https://www.bybit.com/en/help-center/article/How-to-generate-API-keys-on-Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

# =============================================================================
# Optional: Google Trends (pytrends - no key needed, uses scraping)
# Set to true to disable if rate-limited
# =============================================================================
GOOGLE_TRENDS_ENABLED=true

# =============================================================================
# Optional: Notifications (Phase 2+)
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=change_this_to_a_long_random_string_in_production
